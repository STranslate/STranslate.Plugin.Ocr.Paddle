<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelsDirectory">模型位置</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelsDirectory_Description">OCR模型下载存储位置</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelsDirectory_Button">选择</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelSize">模型尺寸</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelSize_Description">选择模型大小，越大精度越高但速度越慢</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_Models">在线模型</sys:String>
