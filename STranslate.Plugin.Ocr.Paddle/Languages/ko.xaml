<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelsDirectory">모델 디렉터리</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelsDirectory_Description">다운로드한 OCR 모델의 저장 위치입니다.</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelsDirectory_Button">선택</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelSize">모델 크기</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_ModelSize_Description">모델 크기를 선택하세요. 클수록 정확도는 높지만 속도는 느려집니다</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_Models">온라인 모델</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_Models_Tip">처음 실행할 때 필요한 모델이 자동으로 다운로드됩니다. 잠시 기다려 주세요.</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_Info">소개</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_Info_Text">이 프로젝트는 OpenVINO Runtime 기반 PaddleOCR V6를 사용하며 Tiny/Small/Medium 세 가지 모델 크기를 지원합니다</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_Link_Source">플러그인 프로젝트 소스</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_Paddle_Link_Other">업스트림 프로젝트 소스</sys:String>

</ResourceDictionary>
